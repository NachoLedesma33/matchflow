# Server Configuration
PORT=3001

# Redis Connection
# For local development (requires Docker or Memurai):
#   docker run -d -p 6379:6379 --name matchflow-redis redis:alpine
REDIS_URL=redis://localhost:6379

# For production use Upstash (https://upstash.com) - free tier:
# REDIS_URL=redis://default:xxx@xxx.upstash.io:xxxx

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

NODE_ENV=development